# =============================================================================
#  RetailAI Agent — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="RetailAI Agent"
APP_VERSION="1.0.0"
ENVIRONMENT=development             # development | staging | production
DEBUG=true
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=text                     # text (dev) | json (prod)

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MIN=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ── First-Boot Admin ──────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@retailai.local
ADMIN_PASSWORD=ChangeMe123!         # MUST change on first login
ADMIN_NAME=System Administrator

# ── Database ──────────────────────────────────────────────────────────────────
DB_DIALECT=sqlite                   # sqlite | postgresql
SQLITE_PATH=./data/db/retailai.db

# PostgreSQL (used when DB_DIALECT=postgresql)
# POSTGRES_DSN=postgresql+asyncpg://user:pass@localhost:5432/retailai
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list (JSON array format)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Service URLs ──────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
HLS_BASE_URL=http://localhost:8888

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_HLS_BASE_URL=http://localhost:8888

# ── CV Pipeline ───────────────────────────────────────────────────────────────
CAMERA_RTSP_URL=                    # e.g. rtsp://192.168.1.100:554/stream
CV_MODEL_PATH=yolo11n.pt
CV_CONFIDENCE=0.45
CV_IOU_THRESHOLD=0.45
CV_INFERENCE_DEVICE=cpu             # cpu | cuda | mps
CV_TARGET_FPS=10
CV_HEATMAP_GRID_SIZE=100

# ── Storage ───────────────────────────────────────────────────────────────────
DATA_DIR=./data
REPORTS_DIR=./data/reports
MODELS_DIR=./data/models
UPLOAD_DIR=./data/uploads

# ── Docker Ports ──────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Privacy (DO NOT CHANGE) ───────────────────────────────────────────────────
# These are locked OFF by the platform — changing them will cause startup errors
FEATURE_CLOUD_SYNC=false
FEATURE_FACIAL_RECOG=false
FEATURE_BIOMETRICS=false
